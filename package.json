{
  "name": "lawyerup-backend",
  "version": "1.0.0",
  "description": "saas apis for multiple mobile app projects",
  "main": "app.js",
  "scripts": {
    "prettier-format": "prettier --config .prettierrc 'src/**/*.js' --write --fix",
    "pretest": "eslint --fix --ignore-path .gitignore .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "NODE_ENV=development nodemon --exec ./node_modules/.bin/babel-node index.js",
    "staging": "NODE_ENV=staging ./node_modules/.bin/babel-node index.js",
    "start": "NODE_ENV=production ./node_modules/.bin/babel-node index.js",
    "migration": "npx sequelize-cli db:migrate",
    "seed": "npx sequelize-cli db:seed:all",
    "seed:admin": "node seed-admin.js",
    "seed:laws": "./node_modules/.bin/babel-node seed-laws.js",
    "seed:laws:force": "./node_modules/.bin/babel-node seed-laws.js --force",
    "seed:demo-user": "node seed-demo-user.js",
    "seed:demo-user:force": "node seed-demo-user.js --force"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:komaldhiman07/LawyerUp-Nodejs.git"
  },
  "keywords": [
    "saas"
  ],
  "author": "Komal",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/komaldhiman07/LawyerUp-Nodejs/issues"
  },
  "homepage": "https://github.com/komaldhiman07/LawyerUp-Nodejs#readme",
  "dependencies": {
    "@babel/register": "^7.13.16",
    "@sendgrid/mail": "^7.6.1",
    "aws-sdk": "^2.990.0",
    "babel-runtime": "^6.26.0",
    "bcrypt": "^5.0.1",
    "body-parser": "^1.19.0",
    "config": "^4.4.1",
    "cookie-parser": "^1.4.4",
    "cors": "^2.8.5",
    "dotenv": "^8.2.0",
    "ejs": "^3.1.6",
    "email-templates": "^10.0.1",
    "express": "^4.17.1",
    "express-validator": "^6.14.0",
    "fcm-node": "^1.6.1",
    "firebase-admin": "^13.10.0",
    "fs": "0.0.1-security",
    "handlebars": "^4.7.7",
    "helmet": "^3.23.3",
    "joi": "^14.3.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^6.2.1",
    "mongoose-paginate": "^5.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.3",
    "path": "^0.12.7",
    "qrcode": "^1.5.1",
    "randomstring": "^1.2.3",
    "speakeasy": "^2.0.0",
    "swagger-ui-express": "^4.1.6",
    "winston": "^3.3.3"
  },
  "devDependencies": {
    "babel-cli": "^6.26.0",
    "babel-core": "^6.26.3",
    "babel-eslint": "^10.0.3",
    "babel-plugin-transform-runtime": "^6.23.0",
    "babel-polyfill": "^6.26.0",
    "babel-preset-env": "^1.7.0",
    "babel-preset-es2015": "^6.24.1",
    "babel-preset-es2017": "^6.24.1",
    "babel-preset-stage-0": "^6.24.1",
    "eslint": "^5.3.0",
    "eslint-config-airbnb": "^17.1.1",
    "eslint-config-airbnb-base": "^14.2.1",
    "eslint-plugin-import": "^2.23.4",
    "ngrok": "^4.3.3",
    "nodemon": "^2.0.7",
    "prettier": "^2.3.1"
  }
}
