PORT=3000

# SEC-01: Use authenticated URI in production (run scripts/setup-mongodb-auth.sh first)
# Development (no auth):
MONGO_DB_URI=mongodb://127.0.0.1:27017/lawyerup
# Production (with auth — replace <password> with value set during setup):
# MONGO_DB_URI=mongodb://lawyerup_app:<password>@127.0.0.1:27017/lawyerup?authSource=admin

# SEC-03: Override default role IDs here if your DB was seeded with different IDs
ADMIN_ROLE_ID=620504e9f47dd88dfc51e183
USER_ROLE_ID=620ca6da33032d8eb3c3b236

# Must be at least 32 random characters — generate with: openssl rand -hex 32
PRIVATE_JWT_SECRET=replace-with-strong-secret-min-32-chars
WEB_URL_LANDING=https://example.com/
LAWYER_UP_HELP_EMAIL=no-reply@example.com

DB_HOST=localhost
DB_USER_NAME=root
DB_PASSWORD=secret
DB_PORT=3306
DB_DATABASE=lawyerup
DB_DIALECT=mysql

AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_BUCKET=your-bucket-name

SENDGRID_API_KEY=your-sendgrid-key
SENDGRID_EMAIL=no-reply@example.com
GMAIL_USERNAME=your-gmail@example.com
GMAIL_PASSWORD=your-gmail-password

# FCM_SERVER_KEY is deprecated — replaced by Firebase Admin SDK below
# FCM_SERVER_KEY=your-fcm-server-key

# Firebase Admin SDK (generate from Firebase Console → Project Settings → Service Accounts)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

LOCATION_MIN_UPDATE_SECONDS=30
REVERSE_GEOCODE_URL=https://nominatim.openstreetmap.org/reverse
REVERSE_GEOCODE_USER_AGENT=lawyerup-backend/1.0
REVERSE_GEOCODE_COUNTRY=us
